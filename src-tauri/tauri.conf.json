{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "轻量化工具集",
  "version": "0.1.3",
  "identifier": "com.the.lightweight-toolset",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "轻量化工具集",
        "width": 912,
        "height": 598,
        "minWidth": 912,
        "minHeight": 598,
        "maxWidth": 912,
        "maxHeight": 598,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
